<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.event.controller.AdminBookingController">

    <top>
        <Label text="All Bookings"
               style="-fx-font-size: 20px; -fx-padding: 10;"/>
    </top>

    <center>
        <TableView fx:id="bookingTable">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="80"/>
                <TableColumn fx:id="userCol" text="User" prefWidth="150"/>
                <TableColumn fx:id="eventCol" text="Event" prefWidth="200"/>
                <TableColumn fx:id="dateCol" text="Date" prefWidth="200"/>
            </columns>
        </TableView>
    </center>

</BorderPane>