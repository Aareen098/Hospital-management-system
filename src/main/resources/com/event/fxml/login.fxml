<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.*?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.event.controller.AuthController">

    <Label text="Login" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="usernameField" promptText="Username" prefWidth="250"/>
    <PasswordField fx:id="passwordField" promptText="Password" prefWidth="250"/>

    <Button text="Login" prefWidth="200" onAction="#handleLogin"/>

    <Label text="Don't have an account?"/>

    <Button text="Go to Register" prefWidth="200" onAction="#goToRegister"/>

</VBox>