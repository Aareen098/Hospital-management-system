<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.event.controller.UserDashboardController">

    <top>
        <Label text="User Dashboard"
               style="-fx-font-size: 20px; -fx-padding: 10;"/>
    </top>

    <left>
        <VBox spacing="10" style="-fx-padding: 10;">
            <Button text="View Events" onAction="#loadEvents"/>
            <Button text="My Bookings" onAction="#loadMyBookings"/>
            <Button text="Logout" onAction="#logout"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>